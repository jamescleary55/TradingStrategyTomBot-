# Tradovate API credentials.
# Get an API key at https://api.tradovate.com (Account → API Access).
# Copy this file to .env and fill in real values. .env is gitignored.

TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=ict-futures-bot
TRADOVATE_APP_VERSION=0.1.0
TRADOVATE_CID=
TRADOVATE_SECRET=

# Use "demo" for the paper-trading environment, "live" for real money.
TRADOVATE_ENV=demo

# Which broker the executor talks to. Options:
#   tradovate (default) | topstepx | dryrun
BROKER=tradovate

# TopstepX (ProjectX API) — only fill in if BROKER=topstepx
PROJECTX_USERNAME=
PROJECTX_API_KEY=
PROJECTX_ACCOUNT_ID=
PROJECTX_BASE=https://api.topstepx.com

# Telegram alerts. Create a bot at @BotFather → grab token.
# Get your chat_id by messaging @userinfobot or @raw_data_bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set ALERT_MACOS=1 to also send native macOS notifications.
ALERT_MACOS=1

# Webhook receiver — shared secret required on inbound payloads.
# Leave empty for no auth (only safe on localhost / tunneled with auth elsewhere).
WEBHOOK_SECRET=
WEBHOOK_PORT=5005
