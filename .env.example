# ict-futures-bot configuration.
# Copy this file to .env and fill in values. .env is gitignored.

# Which broker the executor + data feed talk to.
#   ibkr (default) | tradovate | topstepx | dryrun
BROKER=ibkr

# ── Interactive Brokers (primary) ────────────────────────────────────────────
# IBKR connects over a LOCAL SOCKET to a running TWS or IB Gateway. You log in
# inside the Gateway/TWS app — there is NO username/password/secret in this file.
# One-time setup in IB Gateway (or TWS):
#   Configure → Settings → API → Settings
#     [x] Enable ActiveX and Socket Clients
#     [ ] Read-Only API   ← UNCHECK to place orders (leave checked for data-only)
#     Add 127.0.0.1 to Trusted IPs
#   Account → Market Data Subscriptions → subscribe to CME real-time data
# Ports: 4002 Gateway paper | 4001 Gateway live | 7497 TWS paper | 7496 TWS live
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=17
# Paper vs live is inferred from the port. Set IB_ENV=live to bypass the
# paper-only safety rail on order placement.
IB_ENV=

# ── Alerts ───────────────────────────────────────────────────────────────────
# Telegram: create a bot at @BotFather for the token; get your chat_id from
# @userinfobot or @raw_data_bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Set ALERT_MACOS=1 to also send native macOS notifications.
ALERT_MACOS=1

# ── Webhook receiver ─────────────────────────────────────────────────────────
# Shared secret required on inbound payloads. Leave empty for no auth
# (only safe on localhost / tunneled with auth elsewhere).
WEBHOOK_SECRET=
WEBHOOK_PORT=5005

# ── Optional brokers ─────────────────────────────────────────────────────────
# Tradovate — only if BROKER=tradovate. API key: https://api.tradovate.com
# (Account → API Access). TRADOVATE_ENV: "demo" (paper) or "live" (real money).
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=ict-futures-bot
TRADOVATE_APP_VERSION=0.1.0
TRADOVATE_CID=
TRADOVATE_SECRET=
TRADOVATE_ENV=demo

# TopstepX (ProjectX API) — only if BROKER=topstepx.
PROJECTX_USERNAME=
PROJECTX_API_KEY=
PROJECTX_ACCOUNT_ID=
PROJECTX_BASE=https://api.topstepx.com
